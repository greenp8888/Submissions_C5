# 1. Create .gitignore
echo ".venv/" >> .gitignore
echo "__pycache__/" >> .gitignore
echo "*.pyc" >> .gitignore
echo ".env" >> .gitignore

# 2. If .venv was already tracked, remove it
git rm -r --cached .venv

# 3. Check status
git status

# 4. Commit the .gitignore
git add .gitignore
git commit -m "Add .gitignore to exclude virtual environment and cache files"