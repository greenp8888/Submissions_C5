# Python: use a venv and `pip install -r requirements.txt` (includes langchain-huggingface for embeddings).
OPENROUTER_API_KEY=
# openrouter | anthropic — must match which key you use (UI can override).
LLM_PROVIDER=openrouter
ANTHROPIC_API_KEY=
# Budget Haiku ids only (see ANTHROPIC_BUDGET_MODELS in deep_researcher/config.py).
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
TAVILY_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
# Phase 2 multi-pass (graph currently uses at most 2 analyst passes; UI matches)
# MAX_RESEARCH_ROUNDS=1
# MAX_FOLLOWUP_QUERIES=6
# MAX_EVIDENCE_ITEMS=120
# ANALYST_EVIDENCE_LIMIT=24

# --- Streamlit: Google sign-in (Gmail / @googlemail.com only) ---
# Leave both empty for local testing: the app shows "Log in as anonymous user" instead.
# Create an OAuth 2.0 Web client in Google Cloud Console and add the redirect URI exactly.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match an authorized redirect URI (trailing slash matters if you register it that way).
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:9501/
