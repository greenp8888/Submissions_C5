%% Full app flow: Gradio preflight (human-in-the-loop) then LangGraph.
%% Render: npx -y @mermaid-js/mermaid-cli -i application_flow_with_hitl.mmd -o application_flow_with_hitl.png -w 3200 -H 1800 -b white

flowchart TB
    subgraph hitl["Gradio UI — human-in-the-loop (outside LangGraph)"]
        direction TB
        U[User: question + optional files]
        R[1. Review uploads & question]
        PF[preflight_llm: digest + alignment vs question]
        H{{2. Human: Yes run research / No cancel}}
        U --> R
        R --> PF
        PF --> H
        H -->|No — cancel| U
    end

    H -->|Yes — run full research| INV["app.py: graph.invoke(initial_state)"]

    subgraph lg["LangGraph StateGraph — see langgraph_topology.png / graph.py"]
        direction TB
        INV --> ST([__start__])
        ST --> P[planner → retrieval → analyst → …]
        P --> EN([__end__])
    end

    EN --> OUT[Report, sources, trace in UI]
