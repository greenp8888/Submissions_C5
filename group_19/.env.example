# ── FinanceIQ Server Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit actual credentials.

# ── Required: OpenRouter API Key ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Required: Tavily API Key ──────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Optional: Brevo Email (pre-fills Config UI for all users) ─────────────────
# When set, app pre-populates Email Settings in Config for everyone.
BREVO_API_KEY=xsmtpsib-...
BREVO_FROM_EMAIL=you@yourdomain.com

# ── Optional: Free-model rate-limit throttle (default: 10 seconds) ────────────
# When using free OpenRouter models (ending in :free), the pipeline sleeps
# this many seconds before each LLM call so 5 agents stay under 8 RPM.
# Increase if you still hit 429 errors. Set to 0 to disable.
# RATE_LIMIT_DELAY_SECONDS=10
