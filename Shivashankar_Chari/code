import gradio as gr
from transformers import pipeline
# 1. Initialize the pipeline outside the function so it only loads once
sentiment_model = pipeline("sentiment-analysis")
# 2. Define the function that Gradio will execute
def analyze_sentiment(text):
    # Get the prediction
    result = sentiment_model(text)[0]
    
    label = result['label']
    score = round(result['score'], 4)
    
    # Return the string that will appear in the Gradio 'outputs'
    return f"Sentiment is {label} and confidence {score}."
# 3. Create the interface
demo = gr.Interface(
    fn=analyze_sentiment, # This now matches the function name above
    inputs=gr.Textbox(placeholder="Enter text to analyze..."), 
    outputs="text",
    title="Sentiment Analyzer",
    description="Type a sentence to see if it's positive or negative."
)
# 4. Launch
if __name__ == "__main__":
    demo.launch()
